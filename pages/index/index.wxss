/* 存款区域样式 */
.deposit-section {
  text-align: center;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  position: relative;
  overflow: hidden;
}

.deposit-section::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0) 70%);
  animation: float 6s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  50% {
    transform: translateY(-20rpx) rotate(5deg);
  }
}

.deposit-section .section-title {
  color: white;
  margin-bottom: 36rpx;
  position: relative;
  z-index: 1;
}

.deposit-section .section-title::before {
  background-color: white;
}

.deposit-amount {
  font-size: 72rpx;
  font-weight: bold;
  margin-bottom: 36rpx;
  position: relative;
  z-index: 1;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  animation: countUp 1s ease-out;
}

@keyframes countUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.deposit-actions {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.action-btn {
  padding: 20rpx 40rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.action-btn:hover {
  transform: translateY(-3rpx);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.15);
}

.action-btn:active {
  transform: translateY(0);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.add-btn {
  background-color: rgba(255, 255, 255, 0.2);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.withdraw-btn {
  background-color: white;
  color: #667eea;
  font-weight: 700;
}

/* 自我反省区域样式 */
.reflection-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.2s ease;
}

.reflection-item:hover {
  background-color: #f9f9f9;
  padding-left: 10rpx;
  border-radius: 12rpx;
}

.reflection-item:last-child {
  border-bottom: none;
}

.item-title {
  font-size: 30rpx;
  color: #2c3e50;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.item-title::before {
  content: '';
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #667eea;
}

/* 问题区域样式 */
.problem-item {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.2s ease;
}

.problem-item:hover {
  background-color: #f9f9f9;
  padding: 16rpx;
  border-radius: 16rpx;
  margin-left: -16rpx;
  margin-right: -16rpx;
}

.problem-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}
