<view class="container">
  <!-- 存款区域 -->
  <view class="section deposit-section">
    <view class="section-title">我的存款</view>
    <view class="deposit-amount">¥{{depositAmount}}</view>
    <view class="deposit-actions">
      <button bindtap="addDeposit" class="action-btn add-btn">+ 存入</button>
      <button bindtap="withdrawDeposit" class="action-btn withdraw-btn">- 取出</button>
    </view>
  </view>

  <!-- 自我反省区域 -->
  <view class="section reflection-section">
    <view class="section-title">自我反省</view>
    
    <!-- 家务模块 -->
    <view class="reflection-item">
      <view class="item-title">家务</view>
      <view class="rating-container">
        <text 
          wx:for="{{5}}" 
          wx:key="index"
          class="star {{reflection.housework >= (index + 1) ? 'active' : ''}}"
          bindtap="rateItem" 
          data-item="housework" 
          data-score="{{index + 1}}"
        >★</text>
      </view>
    </view>

    <!-- 赚钱模块 -->
    <view class="reflection-item">
      <view class="item-title">赚钱</view>
      <view class="rating-container">
        <text 
          wx:for="{{5}}" 
          wx:key="index"
          class="star {{reflection.makingMoney >= (index + 1) ? 'active' : ''}}"
          bindtap="rateItem" 
          data-item="makingMoney" 
          data-score="{{index + 1}}"
        >★</text>
      </view>
    </view>

    <!-- 松弛感模块 -->
    <view class="reflection-item">
      <view class="item-title">松弛感</view>
      <view class="rating-container">
        <text 
          wx:for="{{5}}" 
          wx:key="index"
          class="star {{reflection.relaxation >= (index + 1) ? 'active' : ''}}"
          bindtap="rateItem" 
          data-item="relaxation" 
          data-score="{{index + 1}}"
        >★</text>
      </view>
    </view>

    <!-- 小确幸模块 -->
    <view class="reflection-item">
      <view class="item-title">小确幸</view>
      <view class="rating-container">
        <text 
          wx:for="{{5}}" 
          wx:key="index"
          class="star {{reflection.happiness >= (index + 1) ? 'active' : ''}}"
          bindtap="rateItem" 
          data-item="happiness" 
          data-score="{{index + 1}}"
        >★</text>
      </view>
    </view>
  </view>

  <!-- 亟待解决的问题区域 -->
  <view class="section problems-section">
    <view class="section-title">亟待解决的问题</view>
    
    <!-- 问题列表 -->
    <view wx:for="{{problems}}" wx:key="id" class="problem-item">
      <view class="task-item">
        <view class="checkbox {{item.completed ? 'checked' : ''}}" bindtap="toggleProblem" data-id="{{item.id}}"></view>
        <view class="task-text {{item.completed ? 'completed' : ''}}">{{item.text}}</view>
        <text class="delete-btn" bindtap="deleteProblem" data-id="{{item.id}}">🗑️</text>
      </view>
      
      <!-- 子任务列表 -->
      <view class="subtask-list" wx:if="{{item.subtasks && item.subtasks.length > 0}}">
        <view wx:for="{{item.subtasks}}" wx:key="subId" class="subtask-item">
          <view class="checkbox {{subItem.completed ? 'checked' : ''}}" bindtap="toggleSubtask" data-problem-id="{{item.id}}" data-subtask-id="{{subItem.id}}"></view>
          <view class="task-text {{subItem.completed ? 'completed' : ''}}">{{subItem.text}}</view>
          <text class="delete-btn" bindtap="deleteSubtask" data-problem-id="{{item.id}}" data-subtask-id="{{subItem.id}}">🗑️</text>
        </view>
      </view>
      
      <!-- 添加子任务输入框 -->
      <view class="input-container">
        <input 
          placeholder="添加子任务..." 
          class="input" 
          value="{{item.subtaskInput}}"
          bindinput="updateSubtaskInput" 
          data-id="{{item.id}}"
        />
        <button bindtap="addSubtask" data-id="{{item.id}}" class="add-btn">添加</button>
      </view>
    </view>
    
    <!-- 添加问题输入框 -->
    <view class="input-container">
      <input 
        placeholder="添加亟待解决的问题..." 
        class="input" 
        value="{{newProblem}}"
        bindinput="updateNewProblem"
      />
      <button bindtap="addProblem" class="add-btn">添加</button>
    </view>
  </view>
</view>