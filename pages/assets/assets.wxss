.header {
  margin-bottom: 40rpx;
}

.app-title {
  cursor: pointer;
  transition: all 0.2s ease;
  display: inline-block;
}

.app-title:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.deposit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.deposit-header-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.deposit-title {
  font-size: 36rpx;
  font-weight: 700;
  color: white;
}

.pig-icon {
  font-size: 120rpx;
  opacity: 0.3;
}

.deposit-desc {
  margin-bottom: 24rpx;
  font-size: 24rpx;
}

.deposit-amount {
  font-size: 72rpx;
  font-weight: 800;
  color: white;
  font-family: 'Courier New', monospace;
}

.flexible-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.flexible-header-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.history-link {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
}

.flexible-stats {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.stat-box {
  flex: 1;
  background-color: #111;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
}

.stat-label {
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
}

.expense-card {
  background-color: rgba(236, 72, 153, 0.1);
  border: 1rpx solid rgba(236, 72, 153, 0.3);
  border-radius: 24rpx;
  padding: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.expense-left {
  flex: 1;
}

.expense-label {
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.expense-value {
  font-size: 40rpx;
  font-weight: 700;
}

.expense-dots {
  display: flex;
  gap: 8rpx;
  background-color: rgba(236, 72, 153, 0.2);
  padding: 20rpx 24rpx;
  border-radius: 50%;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #ec4899;
  border-radius: 50%;
}
