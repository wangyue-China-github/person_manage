/* 全局样式 - 深色主题 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  background-color: #0a0a0a;
  min-height: 100vh;
  margin-top:50rpx;
  color: #ffffff;
}

.container {
  padding: 24rpx;
}

/* 标题样式 */
.app-title {
  font-size: 64rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
  background: linear-gradient(90deg, #00ffff, #00ffaa);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.app-subtitle {
  font-size: 30rpx;
  color: #888;
  margin-bottom: 40rpx;
}

/* 卡片样式 */
.card {
  background-color: #1a1a1a;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #2a2a2a;
}

/* 霓虹渐变效果 */
.neon-glow-purple {
  box-shadow: 0 0 40rpx rgba(147, 51, 234, 0.3),
              0 0 80rpx rgba(147, 51, 234, 0.15);
}

.neon-glow-cyan {
  box-shadow: 0 0 40rpx rgba(0, 255, 255, 0.3),
              0 0 80rpx rgba(0, 255, 255, 0.15);
}

/* 图标样式 */
.icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.icon-purple {
  background-color: rgba(147, 51, 234, 0.2);
  color: #9333ea;
}

.icon-cyan {
  background-color: rgba(0, 255, 255, 0.2);
  color: #00ffff;
}

.icon-pink {
  background-color: rgba(236, 72, 153, 0.2);
  color: #ec4899;
}

/* 文本样式 */
.text-white {
  color: #ffffff;
}

.text-gray {
  color: #888888;
}

.text-yellow {
  color: #d4ff00;
}

.text-cyan {
  color: #00ffff;
}

.text-pink {
  color: #ec4899;
}

.text-purple {
  color: #a855f7;
}

/* 金额样式 */
.amount-text {
  font-size: 56rpx;
  font-weight: 700;
}

/* 滑块样式 */
.slider-container {
  margin-top: 20rpx;
}

.slider-value {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(90deg, #a855f7, #ec4899);
  color: white;
  padding: 30rpx 60rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 0 40rpx rgba(168, 85, 247, 0.4);
}

.btn-float {
  position: fixed;
  bottom: 180rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #3a3a00;
  color: #d4ff00;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 30rpx rgba(212, 255, 0, 0.3);
}

/* 问题卡片 */
.problem-card {
  background-color: #1a1a1a;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #2a2a2a;
}

.problem-card.expanded {
  border-left: 4rpx solid #3a3a00;
}

.progress-badge {
  background-color: #1a1a1a;
  border: 1rpx solid #333;
  color: #888;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

/* 子任务样式 */
.subtask-container {
  margin-left: 24rpx;
  margin-top: 24rpx;
  padding-left: 24rpx;
  border-left: 2rpx solid #333;
}

.subtask-item {
  background-color: #111111;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.subtask-item.completed {
  opacity: 0.5;
}

.subtask-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #555;
  display: flex;
  align-items: center;
  justify-content: center;
}

.subtask-check.checked {
  background-color: #00ffff;
  border-color: #00ffff;
}

.add-subtask {
  color: #555;
  padding: 20rpx 0;
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #222;
  margin: 40rpx 0;
}

/* 动画效果 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-in {
  animation: fadeInUp 0.5s ease-out;
}
