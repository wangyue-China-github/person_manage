/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  padding: 20rpx;
}

.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #333;
}

/* 评分组件样式 */
.rating-container {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.star {
  font-size: 40rpx;
  color: #e0e0e0;
}

.star.active {
  color: #ffd700;
}

/* 任务列表样式 */
.task-item {
  display: flex;
  align-items: center;
  gap: 15rpx;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.task-item:last-child {
  border-bottom: none;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  background-color: #4caf50;
  border-color: #4caf50;
}

.checkbox.checked::after {
  content: '✓';
  color: white;
  font-size: 20rpx;
  font-weight: bold;
}

.task-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.task-text.completed {
  text-decoration: line-through;
  color: #999;
}

.delete-btn {
  font-size: 32rpx;
  color: #ff4757;
}

/* 子任务样式 */
.subtask-list {
  margin-left: 47rpx;
  margin-top: 10rpx;
}

.subtask-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 0;
  font-size: 24rpx;
  color: #666;
}

/* 输入框样式 */
.input-container {
  display: flex;
  gap: 10rpx;
  margin-top: 20rpx;
}

.input {
  flex: 1;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 15rpx;
  font-size: 28rpx;
}

.add-btn {
  background-color: #4caf50;
  color: white;
  padding: 0 30rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}
