/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  background-color: #f0f2f5;
  min-height: 100vh;
  color: #333;
}

.container {
  padding: 20rpx;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  animation: fadeIn 0.3s ease-out;
  transition: all 0.3s ease;
}

.section:hover {
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.12);
  transform: translateY(-2rpx);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: #2c3e50;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 28rpx;
  background-color: #667eea;
  border-radius: 4rpx;
}

/* 评分组件样式 */
.rating-container {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.star {
  font-size: 44rpx;
  color: #e0e0e0;
  transition: all 0.2s ease;
  cursor: pointer;
}

.star:hover {
  transform: scale(1.1);
}

.star.active {
  color: #ffd700;
  animation: pulse 0.3s ease;
}

@keyframes pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.2);
  }
  100% {
    transform: scale(1);
  }
}

/* 任务列表样式 */
.task-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.2s ease;
}

.task-item:hover {
  background-color: #f9f9f9;
  padding-left: 10rpx;
  border-radius: 12rpx;
}

.task-item:last-child {
  border-bottom: none;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  cursor: pointer;
}

.checkbox:hover {
  border-color: #667eea;
  transform: scale(1.05);
}

.checkbox.checked {
  background-color: #667eea;
  border-color: #667eea;
  animation: checkmark 0.3s ease;
}

@keyframes checkmark {
  0% {
    transform: scale(0.8);
  }
  50% {
    transform: scale(1.2);
  }
  100% {
    transform: scale(1);
  }
}

.checkbox.checked::after {
  content: '✓';
  color: white;
  font-size: 22rpx;
  font-weight: bold;
}

.task-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.task-text.completed {
  text-decoration: line-through;
  color: #999;
  transition: all 0.3s ease;
}

.delete-btn {
  font-size: 32rpx;
  color: #ff4757;
  transition: all 0.2s ease;
  cursor: pointer;
  opacity: 0.6;
}

.delete-btn:hover {
  opacity: 1;
  transform: scale(1.1);
}

/* 子任务样式 */
.subtask-list {
  margin-left: 52rpx;
  margin-top: 12rpx;
  animation: fadeIn 0.3s ease-out 0.1s both;
}

.subtask-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: #666;
  transition: all 0.2s ease;
}

.subtask-item:hover {
  background-color: #f9f9f9;
  padding-left: 8rpx;
  border-radius: 10rpx;
}

/* 输入框样式 */
.input-container {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
  animation: fadeIn 0.3s ease-out 0.2s both;
  justify-content: center;
}

.input {
  flex: 1;
  max-width: 500rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  transition: all 0.2s ease;
  background-color: #f9f9f9;
}

.input:focus {
  border-color: #667eea;
  background-color: #fff;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
  outline: none;
}

.add-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  padding: 0 36rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.add-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.4);
}

.add-btn:active {
  transform: translateY(0);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}
